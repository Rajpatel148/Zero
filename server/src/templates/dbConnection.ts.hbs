import prisma from './prismaInstance';
let isConnected = false;

export async function connectToDB(): Promise<void> {
     if (isConnected) {
     return;
     }

     try {
     await prisma.$connect();
     isConnected = true;
     } catch (err) {
     console.error('Error connecting to PostgreSQL:', err);
     process.exit(1);
     }
     }

     export default connectToDB;