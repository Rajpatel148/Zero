import { Router } from "express";
import * as controller from "../controllers/{{lowercase name}}.controller";

const router = Router();

{{#if api.enabled}}

{{#if api.crud}}

router.post("/", controller.create{{pascalCase name}});
router.get("/", controller.getAll{{pascalCase name}});
router.get("/:id", controller.get{{pascalCase name}}ById);
router.put("/:id", controller.update{{pascalCase name}});
router.delete("/:id", controller.delete{{pascalCase name}});

{{else}}

{{#each api.methods}}

{{#if (eq this "create")}}
router.post("/", controller.create{{pascalCase ../name}});
{{/if}}

{{#if (eq this "read")}}
router.get("/", controller.getAll{{pascalCase ../name}});
router.get("/:id", controller.get{{pascalCase ../name}}ById);
{{/if}}

{{#if (eq this "update")}}
router.put("/:id", controller.update{{pascalCase ../name}});
{{/if}}

{{#if (eq this "delete")}}
router.delete("/:id", controller.delete{{pascalCase ../name}});
{{/if}}

{{/each}}

{{/if}}

{{/if}}

export default router;