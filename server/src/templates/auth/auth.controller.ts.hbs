import { RequestHandler } from "express";
import { ApiResponse, createResponse } from "../utils/apiResponse";
import prisma from "../utils/prismaInstance";
import bcrypt from "bcryptjs";
import jwt from "jsonwebtoken";

const JWT_SECRET = process.env.JWT_SECRET || "{{jwtSecret}}";

export const register: RequestHandler<unknown, ApiResponse, unknown, unknown> = async (req, res) => {
try {
const { email, password, name, ...rest } = req.body as any;

if (!email || !password) {
res.status(400).json(createResponse(false, "Email and password are required", null));
return;
}

// Check if user already exists
const existing = await prisma.{{camelCase userModel}}.findUnique({ where: { email } });
if (existing) {
res.status(409).json(createResponse(false, "User with this email already exists", null));
return;
}

// Hash password
const salt = await bcrypt.genSalt(10);
const hashedPassword = await bcrypt.hash(password, salt);

// Create user
const user = await prisma.{{camelCase userModel}}.create({
data: {
email,
password: hashedPassword,
name: name || "",
...rest,
},
});

// Remove password from response
const { password: _, ...safeUser } = user as any;

res.status(201).json(createResponse(true, "User registered successfully", safeUser));
} catch (error) {
res.status(500).json(createResponse(false, (error as Error).message, null));
}
};

export const login: RequestHandler<unknown, ApiResponse, unknown, unknown> = async (req, res) => {
try {
const { email, password } = req.body as any;

if (!email || !password) {
res.status(400).json(createResponse(false, "Email and password are required", null));
return;
}

// Find user
const user = await prisma.{{camelCase userModel}}.findUnique({ where: { email } });
if (!user) {
res.status(401).json(createResponse(false, "Invalid credentials", null));
return;
}

// Compare password
const isMatch = await bcrypt.compare(password, (user as any).password);
if (!isMatch) {
res.status(401).json(createResponse(false, "Invalid credentials", null));
return;
}

// Generate JWT
const token = jwt.sign(
{ id: (user as any).id, email: (user as any).email },
JWT_SECRET,
{ expiresIn: "7d" }
);

// Remove password from response
const { password: _, ...safeUser } = user as any;

res.status(200).json(createResponse(true, "Login successful", { user: safeUser, token }));
} catch (error) {
res.status(500).json(createResponse(false, (error as Error).message, null));
}
};
