import express from 'express';
import cors from 'cors';
import compression from 'compression';
import { createResponse } from './utils/apiResponse';
import router from './{{output.paths.routes}}';

const app = express();

app.use(express.json());
app.use(express.urlencoded({ extended: true }));
app.use(cors());

// Apply compression middleware
app.use(
compression({
level: 6, // Compression level (0-9)
threshold: 1024, // Compress only if response is > 1KB
filter: (req, res) => {
// Custom filter
if (req.headers['x-no-compression']) {
return false; // Don't compress if header exists
}
return compression.filter(req, res);
},
}),
);

app.get('/health', (req, res) => {
res.status(200).json(createResponse(true, "Server is still healthly and running", null))
});

app.use('{{server.apiPrefix}}',router);

app.use((req, res) => {
res.status(404).json(createResponse(false, req.url + ' Not Found', null));
});

export default app;