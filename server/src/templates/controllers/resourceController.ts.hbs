import { Prisma } from "@prisma/client";
import { RequestHandler } from "express";
import { ApiResponse, createResponse } from "../utils/apiResponse";
{{#if paginationEnabled}}
import { getPaginationParams, paginate } from "../utils/pagination";
{{/if}}
import prisma from "../utils/prismaInstance";

{{#if api.enabled}}

{{#if api.crud}}

export const create{{pascalCase name}}: RequestHandler<unknown, ApiResponse, Prisma.{{pascalCase name}}CreateInput, unknown> = async (req, res) => {
try {
{{#if validationFields}}
// Validation
const errors: string[] = [];
{{#each validationFields}}
{{#if this.required}}
if (req.body.{{@key}} === undefined || req.body.{{@key}} === null || req.body.{{@key}} === '') {
errors.push("{{@key}} is required");
}
{{/if}}
{{#if this.enum}}
if (req.body.{{@key}} != null && ![{{{join this.enum ", "}}}].includes(req.body.{{@key}})) {
errors.push("{{@key}} must be one of: {{joinFields this.enum}}");
}
{{/if}}
{{/each}}
if (errors.length > 0) {
res.status(400).json(createResponse(false, errors.join(", "), null));
return;
}
{{/if}}

const data = await prisma.{{camelCase name}}.create({ data: req.body });
res.status(201).json(createResponse(true, "{{pascalCase name}} created successfully", data));
} catch (error) {
res.status(500).json(createResponse(false, (error as Error).message, null));
}
};

export const getAll{{pascalCase name}}: RequestHandler<unknown, ApiResponse, unknown, unknown> = async (req, res) => {
try {
{{#if paginationEnabled}}
const { page, limit } = getPaginationParams(req.query as Record<string, unknown>, { limit: {{pageLimit}} });
const result = await paginate(prisma.{{camelCase name}}, { page, limit });
res.status(200).json(createResponse(true, "{{pascalCase name}} fetched successfully", result.data, result.pagination));
{{else}}
const data = await prisma.{{camelCase name}}.findMany();
res.status(200).json(createResponse(true, "{{pascalCase name}} fetched successfully", data));
{{/if}}
} catch (error) {
res.status(500).json(createResponse(false, (error as Error).message, null));
}
};

export const get{{pascalCase name}}ById: RequestHandler<{ id: string }, ApiResponse, unknown, unknown> = async (req, res) => {
try {
const data = await prisma.{{camelCase name}}.findUnique({ where: { id: req.params.id } });
if (!data) {
res.status(404).json(createResponse(false, "{{pascalCase name}} not found", null));
return;
}
res.status(200).json(createResponse(true, "{{pascalCase name}} fetched successfully", data));
} catch (error) {
res.status(500).json(createResponse(false, (error as Error).message, null));
}
};

