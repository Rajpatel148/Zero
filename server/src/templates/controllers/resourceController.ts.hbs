export const delete{{pascalCase name}}: RequestHandler<{ id: string }, ApiResponse, unknown, unknown> = async (req, res) => {
try {
await prisma.{{camelCase name}}.delete({ where: { id: req.params.id } });
res.status(200).json(createResponse(true, "{{pascalCase name}} deleted successfully", null));
} catch (error) {
res.status(500).json(createResponse(false, (error as Error).message, null));
}
};

