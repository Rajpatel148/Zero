{
  "name": "zero-backend",
  "version": "1.1.1",
  "description": "A config-driven backend generator that allows developers to define models, features, and structure in a simple config file, and automatically generates a complete, scalable backend with zero repetitive coding.",
  "keywords": [
    "zero",
    "backend",
    "backend generator",
    "nodejs",
    "cli",
    "boilerplate",
    "scaffold",
    "automation",
    "express",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rajpatel148/Zero.git"
  },
  "homepage": "https://github.com/Rajpatel148/Zero#readme",
  "bugs": {
    "url": "https://github.com/Rajpatel148/Zero/issues"
  },
  "license": "ISC",
  "author": "RAJ MOVALIYA",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zero": "dist/bin/zero.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "copy-templates": "node scripts/copy-templates.cjs",
    "build": "tsc && npm run copy-templates",
    "dev": "ts-node --esm bin/zero.ts",
    "start": "node dist/bin/zero.js",
    "lint": "prettier --check '**/*.{ts,js,json,md}'",
    "format": "prettier --write '**/*.{ts,js,json,md}'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/prompts": "^2.4.9",
    "copyfiles": "^2.4.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
